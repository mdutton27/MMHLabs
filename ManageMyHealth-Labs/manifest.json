{
  "manifest_version": 3,
  "name": "ManageMyHealth - Labs",
  "short_name": "MMH Labs",
  "version": "1.0",
  "description": "Copy your lab results from ManageMyHealth as CSV or XML. Does not include patient name, DOB, NHI number, or STI/STD results.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://app.managemyhealth.co.nz/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.managemyhealth.co.nz/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
